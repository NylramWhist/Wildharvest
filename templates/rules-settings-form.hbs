<div class="wildharvest-dialog wildharvest-dialog--wide wildharvest-rules-form">
  <section class="wildharvest-preview__block">
    <label for="wildharvest-loot-mode"><strong>{{labels.activeModeTitle}}</strong></label>
    <p class="hint">{{labels.activeModeHint}}</p>
    <select id="wildharvest-loot-mode" name="lootMode">
      <option value="rarity" {{#if isRarityMode}}selected{{/if}}>{{labels.rarityMode}}</option>
      <option value="value" {{#if isValueMode}}selected{{/if}}>{{labels.valueMode}}</option>
    </select>
  </section>

  <section class="wildharvest-preview__block">
    <strong>{{labels.playerRollTitle}}</strong>
    <p class="hint">{{labels.playerRollHint}}</p>
    <label class="checkbox">
      <input type="checkbox" name="playerRollRules.allowExtraModifier" {{#if playerRollRules.allowExtraModifier}}checked{{/if}}>
      <span>{{labels.allowExtraModifier}}</span>
    </label>
    <label>
      <span>{{labels.maxExtraModifier}}</span>
      <input type="number" name="playerRollRules.maxExtraModifier" value="{{playerRollRules.maxExtraModifier}}" step="1" min="0" max="100">
    </label>
    <label class="checkbox">
      <input type="checkbox" name="playerRollRules.allowRollModeSelection" {{#if playerRollRules.allowRollModeSelection}}checked{{/if}}>
      <span>{{labels.allowRollModeSelection}}</span>
    </label>
  </section>

  <section class="wildharvest-preview__block">
    <strong>{{labels.pointsTitle}}</strong>
    <p class="hint">{{labels.pointsHint}}</p>
    <table class="wildharvest-table wildharvest-rules-table">
      <thead>
        <tr>
          <th scope="col">{{labels.minTotal}}</th>
          <th scope="col">{{labels.lootPoints}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each lootPointBrackets}}
        <tr>
          <td data-label="{{../labels.minTotal}}">
            <input type="number" name="lootPointBrackets.{{index}}.minTotal" value="{{minTotal}}" step="1" aria-label="{{../labels.minTotal}}">
          </td>
          <td data-label="{{../labels.lootPoints}}">
            <input type="number" name="lootPointBrackets.{{index}}.lootPoints" value="{{lootPoints}}" step="1" min="0" aria-label="{{../labels.lootPoints}}">
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>

  <section class="wildharvest-preview__block">
    <strong>{{labels.rarityTitle}}</strong>
    <p class="hint">{{labels.rarityHint}}</p>
    <table class="wildharvest-table wildharvest-rules-table wildharvest-rules-table--rarity">
      <thead>
        <tr>
          <th scope="col">{{labels.name}}</th>
          <th scope="col">{{labels.cost}}</th>
          <th scope="col">{{labels.weight}}</th>
          <th scope="col">{{labels.quantityFormula}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each rarityRules}}
        <tr>
          <td class="wildharvest-rules-table__name" data-label="{{../labels.name}}">{{label}}</td>
          <td data-label="{{../labels.cost}}">
            <input type="number" name="rarityRules.{{id}}.cost" value="{{cost}}" step="1" min="0" aria-label="{{../labels.cost}}: {{label}}">
          </td>
          <td data-label="{{../labels.weight}}">
            <input type="number" name="rarityRules.{{id}}.weight" value="{{weight}}" step="1" min="0" aria-label="{{../labels.weight}}: {{label}}">
          </td>
          <td data-label="{{../labels.quantityFormula}}">
            <input type="text" name="rarityRules.{{id}}.quantityFormula" value="{{quantityFormula}}" aria-label="{{../labels.quantityFormula}}: {{label}}">
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>

  <section class="wildharvest-preview__block">
    <strong>{{labels.valueTitle}}</strong>
    <p class="hint">{{labels.valueHint}}</p>
    <label>
      <span>{{labels.tolerancePercent}}</span>
      <input type="number" name="valueRules.tolerancePercent" value="{{tolerancePercent}}" step="0.1" min="0" max="100">
    </label>
    <table class="wildharvest-table wildharvest-rules-table">
      <thead>
        <tr>
          <th scope="col">{{labels.valueLootPoints}}</th>
          <th scope="col">{{labels.targetGp}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each valueRules}}
        <tr>
          <td data-label="{{../labels.valueLootPoints}}"><input type="number" name="valueRules.brackets.{{index}}.lootPoints" value="{{lootPoints}}" step="1" min="0" aria-label="{{../labels.valueLootPoints}}"></td>
          <td data-label="{{../labels.targetGp}}"><input type="number" name="valueRules.brackets.{{index}}.targetGp" value="{{targetGp}}" step="0.01" min="0" aria-label="{{../labels.targetGp}}"></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fa-solid fa-save" aria-hidden="true"></i>
      {{labels.save}}
    </button>
    <button type="button" data-action="reset-defaults">
      <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
      {{labels.resetDefaults}}
    </button>
  </footer>
</div>
